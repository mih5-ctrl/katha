---
import ArticleCard from './ArticleCard.astro';

interface Article {
  slug: string;
  data: {
    title: string;
    description: string;
    date: Date;
    section: 'unheard-tales' | 'ajanya-kissa' | 'sacred-history' | 'dharmic-itihas';
    readTime?: number;
  };
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

{articles.length > 0 && (
  <section class="mt-16 pt-10 border-t border-site-border">
    <h2 class="text-xs font-bold uppercase tracking-widest text-site-muted mb-6">More to Read</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          slug={article.slug}
          section={article.data.section}
          readTime={article.data.readTime ?? 4}
        />
      ))}
    </div>
  </section>
)}
