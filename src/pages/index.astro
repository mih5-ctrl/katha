---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const sections = [
  {
    num: '01',
    label: 'Unheard Tales',
    href: '/unheard-tales',
    description: 'Real stories most people have never heard',
    gu: false,
  },
  {
    num: '02',
    label: 'અજાણ્યા કિસ્સા',
    href: '/ajanya-kissa',
    description: 'અજાણ્યી, ચોંકાવનારી સત્ય ઘટનાઓ',
    gu: true,
  },
  {
    num: '03',
    label: 'Sacred History',
    href: '/sacred-history',
    description: 'Religious histories told in a new light',
    gu: false,
  },
  {
    num: '04',
    label: 'ધાર્મિક ઇતિહાસ',
    href: '/dharmic-itihas',
    description: 'ધર્મ અને આધ્યાત્મનો ઇતિહાસ',
    gu: true,
  },
];
---

<BaseLayout title="Katha — Stories That Stay With You">
  <Nav />

  <main class="min-h-[calc(100vh-4rem)] flex flex-col items-center justify-center px-5 py-16">

    <!-- Platform identity -->
    <div class="text-center mb-12">
      <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-accent mb-5">Est. 2026</p>
      <h1 class="text-5xl md:text-6xl font-serif font-bold text-site-text tracking-tight mb-4">Katha</h1>
      <p class="text-sm text-site-muted max-w-[220px] mx-auto leading-relaxed tracking-wide">
        Stories that surprise.<br />Histories that inspire.
      </p>
    </div>

    <!-- Decorative divider -->
    <div class="flex items-center gap-3 mb-12 w-full max-w-xs">
      <div class="flex-1 h-px bg-site-border"></div>
      <div class="flex gap-1">
        <span class="w-1 h-1 rounded-full bg-accent/40 inline-block"></span>
        <span class="w-1 h-1 rounded-full bg-accent inline-block"></span>
        <span class="w-1 h-1 rounded-full bg-accent/40 inline-block"></span>
      </div>
      <div class="flex-1 h-px bg-site-border"></div>
    </div>

    <!-- 4 section cards -->
    <div class="grid grid-cols-2 gap-3 w-full max-w-2xl">
      {sections.map(section => (
        <a
          href={section.href}
          class="group relative flex flex-col justify-between bg-white border border-site-border rounded-xl p-5 md:p-6 min-h-[150px] hover:border-accent/50 hover:shadow-lg transition-all duration-200 overflow-hidden"
        >
          <!-- Faint section number -->
          <span class="absolute top-3 right-4 text-5xl font-bold text-site-border/80 leading-none select-none group-hover:text-accent/10 transition-colors">
            {section.num}
          </span>

          <div class="relative">
            <h2 class={`font-bold text-site-text group-hover:text-accent transition-colors leading-snug mb-2 ${section.gu ? 'lang-gujarati text-base md:text-lg' : 'font-serif text-base md:text-lg'}`}>
              {section.label}
            </h2>
            <p class={`text-xs md:text-sm text-site-muted leading-relaxed ${section.gu ? 'lang-gujarati' : ''}`}>
              {section.description}
            </p>
          </div>

          <!-- Arrow -->
          <div class="relative mt-5 flex items-center gap-1 text-xs font-semibold text-accent translate-x-0 group-hover:translate-x-1 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

  </main>

  <footer class="border-t border-site-border py-6">
    <div class="text-center">
      <p class="text-xs text-site-muted tracking-wide">
        © 2026 Katha &nbsp;·&nbsp; All rights reserved.
      </p>
    </div>
  </footer>
</BaseLayout>
